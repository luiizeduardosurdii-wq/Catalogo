# Desenvolvimento local (SQLite)
DATABASE_URL="file:./dev.db"

# Produção (PostgreSQL — Neon, Supabase, etc.)
# DATABASE_URL="postgresql://user:pass@host:5432/catalogo"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET="gere-um-secret-aleatorio-aqui"

# Pagamentos PIX (v2) — false na v1, true para habilitar checkout
PAYMENTS_ENABLED="false"
NEXT_PUBLIC_PAYMENTS_ENABLED="false"

# Mercado Pago (opcional — sem token usa provedor mock em dev)
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""

# Tempo de expiração do pedido PIX (minutos)
PIX_ORDER_EXPIRY_MINUTES="30"
